APP_NAME=Prontuario API
APP_VERSION=0.1.0
ENVIRONMENT=development
API_PREFIX=
OPENAPI_URL=/openapi.json
DOCS_URL=/docs
REDOC_URL=/redoc
SECRET_PROVIDER=env
SECRET_FILE_PATH=.secrets.json
AWS_SECRETS_REGION=us-east-1
AWS_SECRETS_ID=
REQUIRE_MANAGED_SECRETS_IN_DEPLOY=true
REQUIRE_ENCRYPTION_KEY_IN_DEPLOY=true

GZIP_ENABLED=true
GZIP_MINIMUM_SIZE=1000
LOG_LEVEL=INFO
LOG_JSON=false
LOG_REQUEST_BODIES=true
ENFORCE_HTTPS=false
HSTS_ENABLED=false
HSTS_MAX_AGE_SECONDS=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=false

DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/prontuario
DATABASE_ECHO=false
REDIS_URL=redis://localhost:6379/0

S3_BUCKET_NAME=prontuario-dev
S3_REGION=us-east-1
MAX_UPLOAD_SIZE_MB=20
S3_PRESIGNED_EXPIRES_SECONDS=900

JWT_SECRET_KEY=s*jx24wfDpFjkz7FQ^R!73wI9Pc!Xfpi
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXP_MINUTES=60
ENCRYPTION_KEY=MDEyMzQ1Njc4OTAxMjM0NTY3ODkwMTIzNDU2Nzg5MDE=
ENCRYPTION_KEYS_JSON={"v1":"MDEyMzQ1Njc4OTAxMjM0NTY3ODkwMTIzNDU2Nzg5MDE="}
ENCRYPTION_ACTIVE_KEY_VERSION=v1
